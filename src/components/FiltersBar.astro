---
import TagChip from "./TagChip.astro";

interface Props {
  tags: string[];
  types: readonly string[];
  statuses: readonly string[];
}

const { tags, types, statuses } = Astro.props;
---

<section class="filters-bar" aria-label="Project filters">
  <div class="filters-row">
    <label class="search-field" for="project-search">
      <span>Search</span>
      <input
        id="project-search"
        name="project-search"
        type="search"
        placeholder="Title, tags, abstract, summary"
        autocomplete="off"
      />
    </label>

    <label class="sort-field" for="project-sort">
      <span>Sort</span>
      <select id="project-sort" name="project-sort">
        <option value="recently-updated">Recently updated</option>
        <option value="newest">Newest</option>
        <option value="oldest">Oldest</option>
      </select>
    </label>
  </div>

  <div class="chip-groups">
    <div class="chip-group" data-chip-group="type">
      <p class="chip-group-label">Type</p>
      <TagChip label="All" interactive group="type" value="all" active />
      {types.map((type) => <TagChip label={type} interactive group="type" value={type} />)}
    </div>

    <div class="chip-group" data-chip-group="status">
      <p class="chip-group-label">Status</p>
      <TagChip label="All" interactive group="status" value="all" active />
      {statuses.map((status) => <TagChip label={status} interactive group="status" value={status} />)}
    </div>

    <div class="chip-group" data-chip-group="tag">
      <p class="chip-group-label">Tags</p>
      <TagChip label="All" interactive group="tag" value="all" active />
      {tags.map((tag) => <TagChip label={tag} interactive group="tag" value={tag} />)}
    </div>
  </div>
</section>
