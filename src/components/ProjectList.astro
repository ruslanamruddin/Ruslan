---
import StatusBadge from "./StatusBadge.astro";
import TagChip from "./TagChip.astro";
import type { SerializedProject } from "../lib/projects";

interface Props {
  projects: SerializedProject[];
  selectedSlug: string;
}

const { projects, selectedSlug } = Astro.props;

const formatter = new Intl.DateTimeFormat("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
});
---

<aside class="project-list-column" aria-label="Project archive list">
  <ul id="project-list" class="project-list" role="listbox">
    {
      projects.map((project) => {
        const isSelected = project.slug === selectedSlug;

        return (
          <li>
            <button
              type="button"
              class={`project-row${isSelected ? " is-selected" : ""}`}
              aria-selected={isSelected}
              data-project-row
              data-project-slug={project.slug}
              data-project-title={project.title}
              data-project-summary={project.summary}
              data-project-abstract={project.abstract}
              data-project-tags={project.tags.join("|")}
              data-project-type={project.type}
              data-project-status={project.status}
              data-project-date={project.date}
              data-project-updated={project.lastUpdated}
            >
              <div class="project-row-header">
                <h3>{project.title}</h3>
                <StatusBadge status={project.status} compact />
              </div>

              <p class="project-row-summary">{project.summary}</p>

              <div class="project-row-meta">
                <span>{project.type}</span>
                <span>Updated {formatter.format(new Date(project.lastUpdated))}</span>
              </div>

              <div class="project-row-tags">
                {project.tags.slice(0, 3).map((tag) => <TagChip label={tag} />)}
              </div>
            </button>
          </li>
        );
      })
    }
  </ul>
  <p id="project-empty" class="project-empty" hidden>No projects match the current filters.</p>
</aside>
