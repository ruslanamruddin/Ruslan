---
interface Props {
  status: string;
  compact?: boolean;
  id?: string;
}

const { status, compact = false, id } = Astro.props;
const normalized = status.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-+|-+$/g, "");
---

<span id={id} class={`status-badge status-${normalized}${compact ? " is-compact" : ""}`}>{status}</span>
