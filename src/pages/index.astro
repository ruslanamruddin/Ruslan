---
import BaseLayout from "../layouts/BaseLayout.astro";
import StatusBadge from "../components/StatusBadge.astro";
import TagChip from "../components/TagChip.astro";
import { getProjects, serializeProjects, slugFromId } from "../lib/projects";
import { withBase } from "../lib/paths";

const projects = await getProjects();
const serialized = serializeProjects(projects);
const commandProjects = serialized.map((project) => ({
  title: project.title,
  slug: project.slug,
  type: project.type,
  status: project.status,
}));

const pinnedProjects = serialized.filter((project) => project.pinned).slice(0, 4);
const pinned = pinnedProjects.length ? pinnedProjects : serialized.slice(0, 4);

const recentActivity = projects
  .flatMap((project) =>
    project.data.updates.map((update) => ({
      date: update.date,
      note: update.note,
      title: project.data.title,
      slug: slugFromId(project.id),
    })),
  )
  .sort((a, b) => b.date.getTime() - a.date.getTime())
  .slice(0, 8);

const nowStrip = [
  {
    label: "Current direction",
    text: "Writing a methods paper on ML-based placental histology segmentation. Quantitative analysis of prenatal THC + CBD placental datasets.",
  },
  {
    label: "Reading",
    text: "Computational histopathology and biomedical imaging literature. Methods papers on reproducibility and ML evaluation.",
  },
  {
    label: "Building",
    text: "Histoscope platform for human-in-the-loop histology inference. Research-grade ML pipelines for whole-slide image analysis.",
  },
];

const formatter = new Intl.DateTimeFormat("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
});
---

<BaseLayout
  title="Ruslan Amruddin — Research Archive"
  description="Life sciences researcher building ML pipelines and tools for biomedical research."
  commandProjects={commandProjects}
>
  <section class="page-head">
    <h1>Research Archive</h1>
    <p>
      Computational histology, ML for biomedical data, and reproducible research tooling. Work in progress — updated as results develop.
    </p>
  </section>

  <section class="home-grid">
    <div>
      <header style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:0.6rem;">
        <h2>Pinned</h2>
        <a href={withBase("projects/")} style="font-family:var(--font-mono);font-size:var(--text-xs);">All projects</a>
      </header>

      <div class="pinned-grid">
        {
          pinned.map((project) => (
            <article class="pinned-card">
              <header>
                <h3>
                  <a href={withBase(`projects/${project.slug}/`)} style="text-decoration:none;color:inherit;">
                    {project.title}
                  </a>
                </h3>
                <StatusBadge status={project.status} compact />
              </header>

              <p>{project.summary}</p>

              <div style="display:flex;align-items:baseline;justify-content:space-between;gap:0.5rem;">
                <div class="project-row-tags">
                  {project.tags.slice(0, 3).map((tag) => <TagChip label={tag} />)}
                </div>
                <small style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--faint);white-space:nowrap;">
                  {formatter.format(new Date(project.lastUpdated))}
                </small>
              </div>
            </article>
          ))
        }
      </div>
    </div>

    <aside class="now-strip">
      <h2>Status</h2>
      {
        nowStrip.map((item) => (
          <div class="now-item">
            <strong>{item.label}</strong>
            <p>{item.text}</p>
          </div>
        ))
      }
    </aside>
  </section>

  <section>
    <h2 style="margin-bottom:0.5rem;">Log</h2>

    <ul class="activity-feed">
      {
        recentActivity.map((item) => (
          <li class="activity-item">
            <time datetime={item.date.toISOString()}>{formatter.format(item.date)}</time>
            <p>{item.note}</p>
            <a href={withBase(`projects/${item.slug}/`)}>{item.title}</a>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="elsewhere">
    <h2>Elsewhere</h2>
    <p>
      When I'm not at a screen — walking, taking photos of whatever catches my eye, spending time outside, or listening to loud music.
    </p>
  </section>
</BaseLayout>
