---
import BaseLayout from "../../layouts/BaseLayout.astro";
import StatusBadge from "../../components/StatusBadge.astro";
import TagChip from "../../components/TagChip.astro";
import { getProjects, serializeProjects, slugFromId, type ProjectEntry } from "../../lib/projects";
import { withBase } from "../../lib/paths";

export async function getStaticPaths() {
  const projects = await getProjects();

  return projects.map((project) => ({
    params: { slug: slugFromId(project.id) },
    props: { project },
  }));
}

const { project } = Astro.props as { project: ProjectEntry };
const { Content } = await project.render();

const allProjects = await getProjects();
const commandProjects = serializeProjects(allProjects).map((entry) => ({
  title: entry.title,
  slug: entry.slug,
  type: entry.type,
  status: entry.status,
}));

const updates = [...project.data.updates].sort((a, b) => b.date.getTime() - a.date.getTime());
const linkLabels: Record<string, string> = {
  github: "GitHub",
  demo: "Demo",
  poster: "Poster",
  slides: "Slides",
  dataset: "Dataset",
};

const links = Object.entries(project.data.links).filter(([, value]) => Boolean(value));

const formatter = new Intl.DateTimeFormat("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
});
---

<BaseLayout
  title={`${project.data.title} | Research Archive`}
  description={project.data.summary}
  commandProjects={commandProjects}
>
  <article class="paper-layout">
    <header class="paper-header">
      <p style="font-family:var(--font-mono);font-size:var(--text-xs);">
        <a href={withBase(`projects/?project=${slugFromId(project.id)}`)}>Back to archive</a>
      </p>
      <h1>{project.data.title}</h1>
      <p style="color:var(--muted);">{project.data.summary}</p>

      <div class="preview-badges">
        <span class="meta-pill">{project.data.type}</span>
        <StatusBadge status={project.data.status} />
      </div>

      <div class="paper-meta-grid">
        <div>
          <strong>Started</strong>
          <p>{formatter.format(project.data.date)}</p>
        </div>

        <div>
          <strong>Last updated</strong>
          <p>{formatter.format(project.data.last_updated)}</p>
        </div>

        <div>
          <strong>Venue target</strong>
          <p>{project.data.venue_target ?? "Not specified"}</p>
        </div>
      </div>

      <div class="project-row-tags">
        {project.data.tags.map((tag) => <TagChip label={tag} />)}
      </div>
    </header>

    <section>
      <h2>Abstract</h2>
      <p style="max-width:64ch;">{project.data.abstract}</p>
    </section>

    {
      project.data.featured_image ? (
        <section>
          <h2>Figure</h2>
          <figure class="preview-image-wrap">
            <img src={withBase(project.data.featured_image)} alt="Project figure" loading="lazy" />
          </figure>
        </section>
      ) : null
    }

    <section>
      <h2>Links</h2>
      <div class="detail-links">
        {
          links.length ? (
            links.map(([key, value]) => (
              <a class="link-pill" href={value} target="_blank" rel="noreferrer">
                {linkLabels[key] ?? key}
              </a>
            ))
          ) : (
            <p class="muted">No external links yet.</p>
          )
        }
      </div>
    </section>

    <section>
      <h2>Timeline</h2>
      {
        updates.length ? (
          <ul class="timeline">
            {updates.map((entry) => (
              <li>
                <time datetime={entry.date.toISOString()}>{formatter.format(entry.date)}</time>
                <p>{entry.note}</p>
              </li>
            ))}
          </ul>
        ) : (
          <p class="muted">No updates yet.</p>
        )
      }
    </section>

    <section class="article-content">
      <Content />
    </section>
  </article>
</BaseLayout>
