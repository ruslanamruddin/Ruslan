---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FiltersBar from "../../components/FiltersBar.astro";
import ProjectList from "../../components/ProjectList.astro";
import ProjectPreviewPanel from "../../components/ProjectPreviewPanel.astro";
import { PROJECT_STATUSES, PROJECT_TYPES } from "../../lib/constants";
import { getProjects, serializeProjects, uniqueTags } from "../../lib/projects";

const projects = await getProjects();
const serialized = serializeProjects(projects);
const tags = uniqueTags(projects);
const initialProject = serialized[0];
const serializedJson = JSON.stringify(serialized).replace(/</g, "\\u003c");

const commandProjects = serialized.map((project) => ({
  title: project.title,
  slug: project.slug,
  type: project.type,
  status: project.status,
}));
---

<BaseLayout
  title="Projects | Research Archive"
  description="Browse research projects, prototypes, and tools."
  commandProjects={commandProjects}
>
  <section class="page-head">
    <h1>Projects</h1>
    <p>
      Search and filter active work. Use <code>⌘K</code> to jump to any project.
    </p>
  </section>

  {
    initialProject ? (
      <section data-project-archive>
        <FiltersBar tags={tags} types={PROJECT_TYPES} statuses={PROJECT_STATUSES} />

        <div class="projects-shell" style="margin-top:1rem;">
          <ProjectList projects={serialized} selectedSlug={initialProject.slug} />
          <ProjectPreviewPanel project={initialProject} />
        </div>
      </section>
    ) : (
      <section>
        <p class="muted">No projects available yet.</p>
      </section>
    )
  }

  <script type="application/json" id="projects-data" set:html={serializedJson} />

  <script is:inline define:vars={{ baseUrl: import.meta.env.BASE_URL }}>
    (() => {
      const archive = document.querySelector("[data-project-archive]");
      if (!(archive instanceof HTMLElement)) return;

      const dataElement = document.getElementById("projects-data");
      if (!(dataElement instanceof HTMLScriptElement)) return;

      const projects = JSON.parse(dataElement.textContent || "[]");
      if (!Array.isArray(projects) || projects.length === 0) return;

      const projectMap = new Map(projects.map((project) => [project.slug, project]));
      const linkLabels = {
        github: "GitHub",
        demo: "Demo",
        poster: "Poster",
        slides: "Slides",
        dataset: "Dataset",
      };

      const list = document.getElementById("project-list");
      const empty = document.getElementById("project-empty");
      const rows = Array.from(document.querySelectorAll("[data-project-row]"));

      if (!(list instanceof HTMLElement) || !(empty instanceof HTMLElement) || rows.length === 0) {
        return;
      }

      const rowItems = rows
        .map((row) => {
          const item = row.closest("li");
          if (!(item instanceof HTMLElement) || !(row instanceof HTMLButtonElement)) return null;
          return { row, item };
        })
        .filter(Boolean);

      if (rowItems.length === 0) return;

      const searchInput = document.getElementById("project-search");
      const sortSelect = document.getElementById("project-sort");
      const filterChips = Array.from(document.querySelectorAll("[data-filter-chip]"));

      const previewCard = document.getElementById("preview-card");
      const previewTitle = document.getElementById("preview-title");
      const previewSummary = document.getElementById("preview-summary");
      const previewType = document.getElementById("preview-type");
      const previewStatus = document.getElementById("preview-status");
      const previewMeta = document.getElementById("preview-meta");
      const previewVenue = document.getElementById("preview-venue");
      const previewImageWrap = document.getElementById("preview-image-wrap");
      const previewImage = document.getElementById("preview-image");
      const previewAbstract = document.getElementById("preview-abstract");
      const abstractToggle = document.getElementById("preview-abstract-toggle");
      const previewLinks = document.getElementById("preview-links");
      const previewLatest = document.getElementById("preview-latest");
      const readFull = document.getElementById("preview-read-full");
      const mobileToggle = document.getElementById("preview-mobile-toggle");
      const previewColumn = document.querySelector(".project-preview-column");

      if (
        !(searchInput instanceof HTMLInputElement) ||
        !(sortSelect instanceof HTMLSelectElement) ||
        !(previewCard instanceof HTMLElement) ||
        !(previewTitle instanceof HTMLElement) ||
        !(previewSummary instanceof HTMLElement) ||
        !(previewType instanceof HTMLElement) ||
        !(previewStatus instanceof HTMLElement) ||
        !(previewMeta instanceof HTMLElement) ||
        !(previewVenue instanceof HTMLElement) ||
        !(previewImageWrap instanceof HTMLElement) ||
        !(previewImage instanceof HTMLImageElement) ||
        !(previewAbstract instanceof HTMLElement) ||
        !(abstractToggle instanceof HTMLButtonElement) ||
        !(previewLinks instanceof HTMLElement) ||
        !(previewLatest instanceof HTMLElement) ||
        !(readFull instanceof HTMLAnchorElement)
      ) {
        return;
      }

      const formatDate = (value) =>
        new Intl.DateTimeFormat("en-US", {
          month: "short",
          day: "numeric",
          year: "numeric",
        }).format(new Date(value));

      const joinBase = (path) => `${baseUrl}${String(path || "").replace(/^\//, "")}`.replace(/\/{2,}/g, "/");
      const normalizeStatus = (status) =>
        String(status)
          .toLowerCase()
          .replace(/[^a-z0-9]+/g, "-")
          .replace(/^-+|-+$/g, "");

      let abstractExpanded = false;

      const setAbstractState = (expanded) => {
        abstractExpanded = expanded;
        previewAbstract.classList.toggle("is-collapsed", !expanded);
        abstractToggle.textContent = expanded ? "Collapse" : "Expand";
        abstractToggle.setAttribute("aria-expanded", expanded ? "true" : "false");
      };

      const setStatusBadge = (status) => {
        previewStatus.textContent = status;
        previewStatus.className = `status-badge status-${normalizeStatus(status)}`;
      };

      const state = {
        search: "",
        type: "all",
        status: "all",
        tag: "all",
        sort: "recently-updated",
        selected: "",
      };

      const setActiveChip = (group, value) => {
        filterChips.forEach((chip) => {
          const next = chip;
          if (!(next instanceof HTMLElement)) return;
          if (next.getAttribute("data-filter-group") !== group) return;
          next.classList.toggle("is-active", next.getAttribute("data-filter-value") === value);
        });
      };

      const syncControls = () => {
        searchInput.value = state.search;
        sortSelect.value = state.sort;
        setActiveChip("type", state.type);
        setActiveChip("status", state.status);
        setActiveChip("tag", state.tag);
      };

      const setPreviewLinks = (links) => {
        previewLinks.innerHTML = "";

        const entries = Object.entries(links || {}).filter(([, value]) => Boolean(value));
        if (entries.length === 0) {
          const text = document.createElement("p");
          text.className = "muted";
          text.textContent = "No external links yet.";
          previewLinks.append(text);
          return;
        }

        entries.forEach(([key, value]) => {
          const anchor = document.createElement("a");
          anchor.className = "link-pill";
          anchor.href = String(value);
          anchor.target = "_blank";
          anchor.rel = "noreferrer";
          anchor.textContent = linkLabels[key] || key;
          previewLinks.append(anchor);
        });
      };

      const setLatest = (updates) => {
        previewLatest.innerHTML = "";

        if (!Array.isArray(updates) || updates.length === 0) {
          const emptyText = document.createElement("p");
          emptyText.className = "muted";
          emptyText.textContent = "No timeline updates yet.";
          previewLatest.append(emptyText);
          return;
        }

        const latest = updates[0];
        const text = document.createElement("p");
        const strong = document.createElement("strong");
        strong.textContent = "Latest:";
        text.append(strong, ` ${formatDate(latest.date)} — ${latest.note}`);
        previewLatest.append(text);
      };

      const syncUrl = () => {
        if (!state.selected) return;
        const url = new URL(window.location.href);
        url.searchParams.set("project", state.selected);
        window.history.replaceState({}, "", url);
      };

      const renderPreview = (project) => {
        previewCard.classList.remove("is-swapping");
        window.requestAnimationFrame(() => {
          previewCard.classList.add("is-swapping");
          window.setTimeout(() => previewCard.classList.remove("is-swapping"), 180);
        });

        previewTitle.textContent = project.title;
        previewSummary.textContent = project.summary;
        previewType.textContent = project.type;
        setStatusBadge(project.status);
        previewMeta.textContent = `Updated ${formatDate(project.lastUpdated)}`;

        if (project.venueTarget) {
          previewVenue.hidden = false;
          previewVenue.textContent = `Venue: ${project.venueTarget}`;
        } else {
          previewVenue.hidden = true;
          previewVenue.textContent = "";
        }

        if (project.featuredImage) {
          previewImageWrap.hidden = false;
          previewImage.src = joinBase(project.featuredImage);
        } else {
          previewImageWrap.hidden = true;
          previewImage.src = "";
        }

        previewAbstract.textContent = project.abstract;
        setAbstractState(false);
        setPreviewLinks(project.links);
        setLatest(project.updates);
        readFull.href = joinBase(`projects/${project.slug}/`);
      };

      const renderSelection = () => {
        rowItems.forEach(({ row }) => {
          const isSelected = row.getAttribute("data-project-slug") === state.selected;
          row.classList.toggle("is-selected", isSelected);
          row.setAttribute("aria-selected", isSelected ? "true" : "false");
        });

        const project = projectMap.get(state.selected);
        if (project) {
          renderPreview(project);
          syncUrl();
        }
      };

      const compareRows = (left, right) => {
        const leftRow = left.row;
        const rightRow = right.row;

        const leftDate =
          state.sort === "oldest" || state.sort === "newest"
            ? leftRow.getAttribute("data-project-date")
            : leftRow.getAttribute("data-project-updated");
        const rightDate =
          state.sort === "oldest" || state.sort === "newest"
            ? rightRow.getAttribute("data-project-date")
            : rightRow.getAttribute("data-project-updated");

        const leftTime = new Date(String(leftDate || "")).getTime();
        const rightTime = new Date(String(rightDate || "")).getTime();

        if (state.sort === "oldest") {
          return leftTime - rightTime;
        }

        return rightTime - leftTime;
      };

      const getVisibleRows = () => rowItems.filter(({ item }) => !item.hidden).map(({ row }) => row);

      const applyFilters = () => {
        const query = state.search.trim().toLowerCase();

        rowItems.forEach(({ row, item }) => {
          const title = row.getAttribute("data-project-title") || "";
          const summary = row.getAttribute("data-project-summary") || "";
          const abstract = row.getAttribute("data-project-abstract") || "";
          const tags = (row.getAttribute("data-project-tags") || "").split("|").filter(Boolean);
          const type = row.getAttribute("data-project-type") || "";
          const status = row.getAttribute("data-project-status") || "";

          const searchable = `${title} ${summary} ${abstract} ${tags.join(" ")}`.toLowerCase();
          const searchMatch = !query || searchable.includes(query);
          const typeMatch = state.type === "all" || state.type === type;
          const statusMatch = state.status === "all" || state.status === status;
          const tagMatch = state.tag === "all" || tags.includes(state.tag);

          item.hidden = !(searchMatch && typeMatch && statusMatch && tagMatch);
        });

        const visible = rowItems.filter(({ item }) => !item.hidden);
        visible.sort(compareRows).forEach(({ item }) => list.append(item));

        empty.hidden = visible.length > 0;

        const visibleRows = getVisibleRows();
        const selectedVisible = visibleRows.some((row) => row.getAttribute("data-project-slug") === state.selected);

        if (!selectedVisible) {
          state.selected = visibleRows[0]?.getAttribute("data-project-slug") || "";
        }

        renderSelection();
      };

      rowItems.forEach(({ row }) => {
        row.addEventListener("click", () => {
          const slug = row.getAttribute("data-project-slug");
          if (!slug) return;
          state.selected = slug;
          renderSelection();
        });
      });

      searchInput.addEventListener("input", () => {
        state.search = searchInput.value;
        applyFilters();
      });

      sortSelect.addEventListener("change", () => {
        state.sort = sortSelect.value;
        applyFilters();
      });

      filterChips.forEach((chip) => {
        chip.addEventListener("click", () => {
          const node = chip;
          if (!(node instanceof HTMLElement)) return;

          const group = node.getAttribute("data-filter-group");
          const value = node.getAttribute("data-filter-value") || "all";
          if (!group) return;

          if (group === "type") state.type = value;
          if (group === "status") state.status = value;
          if (group === "tag") state.tag = value;

          setActiveChip(group, value);
          applyFilters();
        });
      });

      abstractToggle.addEventListener("click", () => {
        setAbstractState(!abstractExpanded);
      });

      if (mobileToggle instanceof HTMLButtonElement && previewColumn instanceof HTMLElement) {
        mobileToggle.addEventListener("click", () => {
          const collapsed = previewColumn.classList.toggle("is-collapsed");
          mobileToggle.textContent = collapsed ? "Show preview" : "Hide preview";
          mobileToggle.setAttribute("aria-expanded", collapsed ? "false" : "true");
        });
      }

      window.addEventListener("archive:select", (event) => {
        const detail = event instanceof CustomEvent ? event.detail : null;
        const slug = detail?.slug;
        if (!slug || !projectMap.has(slug)) return;

        state.search = "";
        state.type = "all";
        state.status = "all";
        state.tag = "all";
        state.selected = slug;

        syncControls();
        applyFilters();
      });

      const slugFromUrl = new URL(window.location.href).searchParams.get("project");
      if (slugFromUrl && projectMap.has(slugFromUrl)) {
        state.selected = slugFromUrl;
      } else {
        state.selected = rowItems[0]?.row.getAttribute("data-project-slug") || "";
      }

      syncControls();
      applyFilters();
    })();
  </script>
</BaseLayout>
